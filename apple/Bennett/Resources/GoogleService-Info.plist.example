<?xml version="1.0" encoding="UTF-8"?>
<!--
  Replace this file with the real GoogleService-Info.plist downloaded from
  Firebase Console -> Project Settings -> Your apps -> iOS app.
  Rename to: GoogleService-Info.plist
  This .example file is excluded from the build by project.yml.
-->
<plist version="1.0">
<dict>
    <key>API_KEY</key>
    <string>REPLACE_ME</string>
    <key>BUNDLE_ID</key>
    <string>com.bennett.cos</string>
    <key>CLIENT_ID</key>
    <string>REPLACE_ME</string>
    <key>REVERSED_CLIENT_ID</key>
    <string>REPLACE_ME</string>
    <key>GCM_SENDER_ID</key>
    <string>REPLACE_ME</string>
    <key>GOOGLE_APP_ID</key>
    <string>REPLACE_ME</string>
    <key>PROJECT_ID</key>
    <string>REPLACE_ME</string>
    <key>STORAGE_BUCKET</key>
    <string>REPLACE_ME</string>
    <key>IS_ADS_ENABLED</key>
    <false/>
    <key>IS_ANALYTICS_ENABLED</key>
    <false/>
    <key>IS_APPINVITE_ENABLED</key>
    <true/>
    <key>IS_GCM_ENABLED</key>
    <true/>
    <key>IS_SIGNIN_ENABLED</key>
    <true/>
</dict>
</plist>
