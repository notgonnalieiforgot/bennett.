# Web client env. Copy to .env.local and fill in.
# These values are PUBLIC — Firebase web config, not secrets.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Override only when running web against a remote backend.
# Leave blank in dev — vite proxies /api to localhost:3000.
VITE_API_BASE_URL=
