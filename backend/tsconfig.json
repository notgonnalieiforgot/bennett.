{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@bennett/shared": ["../shared/types/index.ts"],
      "@bennett/shared/*": ["../shared/types/*"]
    }
  },
  "include": ["api/**/*", "lib/**/*", "../shared/types/**/*"]
}
