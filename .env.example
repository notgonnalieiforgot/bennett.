# Copy this file to .env and fill in your values before running the backend.
# NEVER commit .env to version control.

# Anthropic
ANTHROPIC_API_KEY=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Stripe
